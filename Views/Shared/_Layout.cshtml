<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EduTrip</title>

    <!-- Bootstrap CSS -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet" />

    <style>
        :root {
            --edu-dark-blue: #1F2A44;
            --edu-mid-blue: #3F8CCB;
            --edu-light-blue: #6FB3E0;
            --edu-pale-blue: #A9D3F0;
            --edu-yellow: #F4C542;
        }

        /* ── Navbar ── */
        .navbar {
            background-color: var(--edu-dark-blue);
            box-shadow: 0 2px 12px rgba(0,0,0,0.25);
            padding: 10px 0;
        }

        .navbar-brand img {
            height: 50px;
            width: 50px;
            object-fit: contain;
            transition: opacity 0.2s ease;
        }

            .navbar-brand img:hover {
                opacity: 0.85;
            }

        /* Nav links */
        .navbar .nav-link {
            color: rgba(255,255,255,0.85) !important;
            font-weight: 500;
            padding: 8px 16px;
            border-radius: 6px;
            transition: background 0.2s, color 0.2s;
        }

            .navbar .nav-link:hover {
                background-color: rgba(255,255,255,0.1);
                color: white !important;
            }

            .navbar .nav-link.active {
                background-color: var(--edu-mid-blue);
                color: white !important;
            }

        /* Brand name "Edu" is mid-blue, "Trip" is white */
        .navbar-brand .edu {
            color: var(--edu-mid-blue);
            font-weight: bold;
            font-size: 1.3rem;
        }

        .navbar-brand .trip {
            color: white;
            font-weight: bold;
            font-size: 1.3rem;
        }

        /* ── Buttons ── */
        .btn-edu {
            background-color: var(--edu-mid-blue);
            color: white;
            border: none;
            border-radius: 8px;
            transition: background 0.2s;
        }

            .btn-edu:hover {
                background-color: var(--edu-dark-blue);
                color: white;
            }

        .btn-cta {
            background-color: var(--edu-yellow);
            color: var(--edu-dark-blue);
            font-weight: bold;
            border: none;
            border-radius: 8px;
            transition: filter 0.2s;
        }

            .btn-cta:hover {
                filter: brightness(0.92);
                color: var(--edu-dark-blue);
            }

        /* ── Cards ── */
        .mentor-card {
            border-left: 4px solid var(--edu-light-blue);
            transition: transform 0.2s, box-shadow 0.2s;
        }

            .mentor-card:hover {
                transform: translateY(-3px);
                box-shadow: 0 6px 20px rgba(63,140,203,0.15);
            }

        /* ── Main content spacing ── */
        body {
            background-color: #f5f8fb;
            color: var(--edu-dark-blue);
        }

        main {
            min-height: calc(100vh - 160px);
        }

        /* ── Footer ── */
        footer {
            background-color: var(--edu-dark-blue);
            color: rgba(255,255,255,0.8);
        }

            footer p {
                margin: 0;
                font-size: 0.9rem;
            }
    </style>
</head>
<body>

    <!-- ===== NAVBAR ===== -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">

            <!-- LOGO + BRAND NAME -->
            <a class="navbar-brand d-flex align-items-center gap-2"
               asp-controller="Home"
               asp-action="Index">
                <img src="~/logo5.png" alt="EduTrip Logo" />
                <span>
                    <span class="edu">Edu</span><span class="trip">Trip</span>
                </span>
            </a>
