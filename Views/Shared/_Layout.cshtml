<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!--
        @ViewData["Title"] → Each page sets its own title.
        Example: from the Mentor page, Title = "Browse Mentors"
        This line picks that up and puts it in the browser tab.
    -->
    <title>@ViewData["Title"] - EduTrip</title>

    <!-- Bootstrap CSS — gives us buttons, cards, grid layout for free -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />

    <!-- Our custom colors using CSS variables from EduTrip brand -->
    <style>
        :root {
            --edu-dark-blue:  #1F2A44;   /* "Trip" text color, navbar background */
            --edu-mid-blue:   #3F8CCB;   /* "Edu" text color, primary buttons */
            --edu-light-blue: #6FB3E0;   /* Card borders, hover states */
            --edu-pale-blue:  #A9D3F0;   /* Highlights, backgrounds */
            --edu-yellow:     #F4C542;   /* CTA buttons, badges */
        }

        /* Navbar styling */
        .navbar {
            background-color: var(--edu-dark-blue); /* Dark navy navbar */
        }

        /* Brand name "Edu" is mid-blue, "Trip" is white */
        .navbar-brand .edu  { color: var(--edu-mid-blue); font-weight: bold; }
        .navbar-brand .trip { color: white; font-weight: bold; }

        /* Primary action buttons use our brand mid-blue */
        .btn-edu {
            background-color: var(--edu-mid-blue);
            color: white;
            border: none;
        }
        .btn-edu:hover {
            background-color: var(--edu-dark-blue); /* Darken on hover */
            color: white;
        }

        /* Yellow CTA button (Book Now, Pay Now, etc.) */
        .btn-cta {
            background-color: var(--edu-yellow);
            color: var(--edu-dark-blue);
            font-weight: bold;
            border: none;
        }

        /* Mentor cards get a light-blue left border as accent */
        .mentor-card {
            border-left: 4px solid var(--edu-light-blue);
        }
    </style>
</head>

<body>
    <!-- ===== NAVBAR (appears on every page because it's in _Layout) ===== -->
    <nav class="navbar navbar-expand-lg navbar-dark">
        <div class="container">

            <!-- Logo/Brand — clicking it goes to Home page -->
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">
                <span class="edu">Edu</span><span class="trip">Trip</span>
            </a>

            <!-- Navigation Links -->
            <div class="navbar-nav ms-auto">
                <!-- asp-controller and asp-action generate the URL automatically -->
                <!-- asp-controller="Mentor" asp-action="Index" → /Mentor/Index -->
                <a class="nav-link text-white" asp-controller="Mentor" asp-action="Index">
                    Browse Mentors
                </a>
                <a class="nav-link text-white" asp-controller="Dashboard" asp-action="Index">
                    My Bookings
                </a>
            </div>
        </div>
    </nav>

    <!-- ===== MAIN CONTENT (each page injects its HTML here) ===== -->
    <main class="container mt-4">
        <!--
            @RenderBody() is the MAGIC LINE.
            Whatever HTML is in Index.cshtml, Details.cshtml, etc.
            gets inserted RIGHT HERE at runtime.
            The layout is the frame, RenderBody is the picture inside.
        -->
        @RenderBody()
    </main>

    <!-- ===== FOOTER ===== -->
    <footer class="text-center py-4 mt-5" style="background-color: var(--edu-dark-blue); color: white;">
        <p>© 2024 EduTrip — Your Journey, Your Mentor</p>
    </footer>

    <!-- Bootstrap JS (needed for dropdowns, modals, etc.) -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

    <!--
        @RenderSection("Scripts", required: false)
        Some pages need extra JavaScript (like the booking page).
        This lets individual pages add their own <script> tags
        without putting them on EVERY page.
    -->
    @RenderSection("Scripts", required: false)
</body>
</html>